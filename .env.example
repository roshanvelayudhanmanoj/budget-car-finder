PORT=3000
JWT_SECRET=your_super_secret_key_change_this_in_production

# MongoDB Atlas connection string (include database name before ?)
# Example: mongodb+srv://USER:PASSWORD@cluster.mongodb.net/budget_car_finder?retryWrites=true&w=majority
MONGODB_URI=mongodb://USERNAME:PASSWORD@host1:27017,host2:27017,host3:27017/budget_car_finder?ssl=true&replicaSet=your-replica-set&authSource=admin
